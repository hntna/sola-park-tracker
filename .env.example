# Sao chép file này thành .env (cho chạy local) và điền giá trị thật.
# .env KHÔNG được commit lên GitHub (đã có trong .gitignore).
# Trên GitHub Actions: đặt các giá trị này trong Settings > Secrets and variables > Actions.

# --- Gemini (Google AI Studio) ---
# Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Apify (nguồn Facebook) ---
# Token tại https://console.apify.com/settings/integrations
APIFY_TOKEN=
# Id actor Facebook Groups Scraper bạn chọn (định dạng owner~actor-name)
APIFY_ACTOR_ID=apify~facebook-groups-scraper
# Danh sách URL group, cách nhau bởi dấu phẩy
GROUP_URLS=https://www.facebook.com/groups/xxxx,https://www.facebook.com/groups/yyyy
FB_MAX_POSTS=50
# Tùy chọn: nếu actor nhận cookie qua input (dán JSON cookie 1 dòng). Thường để trống
# và cấu hình cookie trực tiếp trong actor trên Apify Console cho an toàn.
FB_COOKIES_JSON=

# --- Firebase (Firestore) ---
# Dán TOÀN BỘ nội dung file service-account JSON vào đây (1 dòng).
FIREBASE_SA_JSON=
